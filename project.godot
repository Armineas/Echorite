; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but changes to the values here will take effect.

config_version=5

[application]

config/name="Chroniques de l'Échorite"
config/description="Un RPG narratif en quatre histoires parallèles."
run/main_scene="res://src/ui/MainMenu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://assets/icon.svg"

[autoload]

GSM="*res://src/autoload/GameStateManager.gd"
SaveSystem="*res://src/autoload/SaveSystem.gd"
SceneSequencer="*res://src/autoload/SceneSequencer.gd"
SceneRouter="*res://src/autoload/SceneRouter.gd"
DialogueEngine="*res://src/core/dialogue/DialogueEngine.gd"
CompanionRegistry="*res://src/core/companions/CompanionRegistry.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

