      "act": 2,
      "nodes": {

        "start": {
          "type": "description",
          "text": {"fr": "Cabinet de travail. Varek reçoit le rapport de Veyra — une analyste du troisième service, pas de Sehn."},
          "next": "veyra_rapport"
        },

        "veyra_rapport": {
          "type": "line",
          "speaker": "Veyra",
          "text": {"fr": "Les chiffres de satisfaction provinciale de Sehn. Je les ai comparés aux données brutes du recensement. Il y a un écart systématique de sept à douze points."},
          "next": "varek_demande_clarif"
        },

        "varek_demande_clarif": {
          "type": "line",
          "speaker": "Varek",
          "text": {"fr": "Un écart de mesure ou un ajustement délibéré ?"},
          "next": "veyra_repond_ecart"
        },

        "veyra_repond_ecart": {
          "type": "line",
          "speaker": "Veyra",
          "text": {"fr": "Le sens de l'ajustement est toujours le même. Toujours vers le haut. Les mauvais chiffres ne remontent pas jusqu'à vous."},
          "next": "varek_prend_rapport"
        },

        "varek_prend_rapport": {
          "type": "description",
          "text": {"fr": "Varek prend le rapport. Il ne dit rien pendant quinze secondes."},
          "next": "varek_note_sehn"
        },

        "varek_note_sehn": {
          "type": "line",
          "speaker": "Varek",
          "internal": true,
          "text": {"fr": "Sehn filtre les rapports depuis combien de temps ? Et si les rapports sur Vel'Shan avaient aussi été filtrés — pas vers le haut, mais vers un autre bureau ?"},
          "next": "choix_sehn_reaction"
        },

        "choix_sehn_reaction": {
          "type": "choice",
          "choices": [
            {
              "text": {"fr": "Remercier Veyra et classer. Enquêter discrètement sur Sehn."},
              "next": "varek_enquete_sehn",
              "effects": []
            },
            {
              "text": {"fr": "Convoquer Sehn immédiatement."},
              "next": "varek_convoque_sehn",
              "effects": []
            }
          ]
        },

        "varek_enquete_sehn": {
          "type": "line",
          "speaker": "Varek",
          "text": {"fr": "Gardez ça entre nous pour l'instant. Je veux les données brutes des six derniers mois."},
          "next": "fin_sehn_discret"
        },

        "fin_sehn_discret": {
          "type": "auto",
          "effects": [
            {"type": "complete_scene", "character": "varek", "act": 2, "scene_id": "varek_a2_s4_sehn_premier_doute"}
          ],
          "next": "end"
        },

        "varek_convoque_sehn": {
          "type": "description",
          "text": {"fr": "Sehn arrive deux minutes plus tard. Il ne semble pas surpris."},
          "next": "sehn_arrive_convoque"
        },

        "sehn_arrive_convoque": {
          "type": "line",
          "speaker": "Sehn",
          "text": {"fr": "Sire."},
          "next": "varek_montre_rapport"
        },

        "varek_montre_rapport": {
          "type": "description",
          "text": {"fr": "Varek pose le rapport de Veyra sur le bureau, face visible. Il ne dit rien."},
          "next": "sehn_regarde"
        },

        "sehn_regarde": {
          "type": "line",
          "speaker": "Sehn",
          "text": {"fr": "Les chiffres bruts créent de la panique inutile dans les rangs. J'ai exercé un jugement de présentation."},
          "next": "varek_repond_sehn"
        },

        "varek_repond_sehn": {
          "type": "line",
          "speaker": "Varek",
          "text": {"fr": "Je ne vous ai pas demandé votre jugement de présentation. Je vous ai demandé des rapports exacts."},
          "next": "fin_sehn_convoque"
        },

        "fin_sehn_convoque": {
          "type": "auto",
          "effects": [
            {"type": "complete_scene", "character": "varek", "act": 2, "scene_id": "varek_a2_s4_sehn_premier_doute"}
          ],
          "next": "end"
        }
      }
    },

