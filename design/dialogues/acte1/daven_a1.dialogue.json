          "next": "end"
        },

        "daven_ferme_fenetre": {
          "type": "description",
          "text": {"fr": "Il ferme la fenêtre. Ce n'était pas la première fois. Ce ne sera pas la dernière."},
          "next": "fin_cp1_daven_passe"
        },

        "fin_cp1_daven_passe": {
